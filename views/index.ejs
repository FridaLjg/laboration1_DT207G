<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Startsida</title>
    <link rel="stylesheet" href="css/styles.css">
</head>

<body>
    <nav>
        <ul>
            <li><a href="/">Startsida</a></li>
            <li><a href="/add">Lägg till kurs</a></li>
            <li><a href="/about">Om applikationen</a></li>
        </ul>
    </nav>

    <div class="container">
    <h1>Startsida</h1>

    <h2>Fridas CV</h2>

        <div class="courselist">
            <%
            courses.forEach(course => {
                %>
                <article>
                    <p><%= course.coursecode %> - <%= course.coursename %> - <%= course.syllabus %> - <%= course.progression %></p>
                </article>
                <%
            });
            %>
        </div>

    </div>
</body>

</html>