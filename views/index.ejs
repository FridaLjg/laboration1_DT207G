<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Startsida</title>
    <link rel="stylesheet" href="css/styles.css">
</head>

<body>
    <nav>
        <ul>
            <li><a href="/">Startsida</a></li>
            <li><a href="/add">Lägg till kurs</a></li>
            <li><a href="/about">Om applikationen</a></li>
        </ul>
    </nav>

    <div class="container">
        <h1>Startsida</h1>

        <h2>Fridas CV</h2>

        <div class="courselist">
            <table>
                <thead>
                    <tr>
                        <th>Kurskod</th>
                        <th>Kursnamn</th>
                        <th>Kursplan</th>
                        <th>Progression</th>
                        <th>Radera kurs</th>
                    </tr>
                </thead>

                <tbody>
                    <% courses.forEach(course=> {
                        %>
                        <tr>
                            <td>
                                <%= course.coursecode %>
                            </td>
                            <td>
                                <%= course.coursename %>
                            </td>
                            <td>
                                <%= course.syllabus %>
                            </td>
                            <td>
                                <%= course.progression %>
                            </td>
                            <td>
                                <form action="/courses/delete/<%= course.id %>" method="POST">
                                    <button type="submit">Radera</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>

    </div>
</body>

</html>